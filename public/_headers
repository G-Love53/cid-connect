# Order matters: first match wins. Keep hashed Vite assets immutable; avoid forcing
# must-revalidate on every file (that can slow repeat visits).
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=3600
