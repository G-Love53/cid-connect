# Copy to `.env` for local dev. On Netlify/Vercel, set these in Site settings → Environment variables.
# Get URL + anon key from Famous → Database / project settings (not committed to Git).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.databasepad.com
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Canonical public URL for password-reset and magic-link redirects (production custom domain).
# Required on Netlify — must match Supabase Auth site_url. See docs/CUSTOM_DOMAIN.md.
VITE_SITE_URL=https://connect.commercialinsurance-direct.com

# Optional — CID-PDF-API base for /api/connect (insurance data from cid-postgres).
# When set, policies/quotes/documents/claims/COI/chat use the API with X-User-Email / X-User-Id.
# COI with an attachment: single multipart POST /api/connect/coi/request (field "requirements") — deploy API before relying on this.
# VITE_CID_API_URL=https://cid-pdf-api.onrender.com
#
# Bind / renew: the Connect SPA does not perform in-app Famous policy inserts for bind.
# Policies for the insured UI come from cid-postgres via S6 (operator) when using the bridge,
# or from Famous tables in legacy mode (VITE_CID_API_URL unset). Quote/renew links go to segment intake + API.
